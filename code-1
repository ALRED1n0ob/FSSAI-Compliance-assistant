    sigEl.innerHTML = `Signed by: ${sigs}`;
  } else {
    sigEl.innerHTML = `Will be signed as <span class="who">${currentUser ? currentUser.name : '—'}</span> when saved`;
  }
}

async function saveDailyLog(){
  const today = todayStr();
  const now = new Date().toISOString();
  const readings = {};
  document.querySelectorAll('.temp-input').forEach(inp=>{
    const uid = inp.dataset.unit;
    const timeInp = document.querySelector(`.time-input[data-unit="${uid}"]`);
    const prior = dailyLogSnapshot.readings ? dailyLogSnapshot.readings[uid] : null;
    const changed = !prior || prior.temp !== inp.value;
    readings[uid] = {
      temp: inp.value,
      time: timeInp ? timeInp.value : '',
      by: changed ? (currentUser ? currentUser.name : 'unknown') : (prior ? prior.by : null),
      at: changed ? now : (prior ? prior.at : null)
    };
  });
  const priorSignatures = dailyLogSnapshot.signatures || [];
  const entry = {
    readings,
    checks: {
      pest: document.getElementById('dl-pest').checked,
      waste: document.getElementById('dl-waste').checked,
      water: document.getElementById('dl-water').checked,
      hygiene: document.getElementById('dl-hygiene').checked,
      oil: document.getElementById('dl-oil').checked,
      surfaces: document.getElementById('dl-surfaces').checked,
    },
    notes: document.getElementById('dl-notes').value,
    signatures: [...priorSignatures, {by: currentUser ? currentUser.name : 'unknown', at: now}],
    savedAt: now
  };
  DATA.dailyLogs[today] = entry;
  await saveData();
  document.getElementById('dl-saved-msg').textContent = 'Saved ✓';
  showToast('Today\'s log signed and saved');
  renderDailyLog();
  renderDashboard();
}

