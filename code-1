      await saveData();
      showToast('Staff updated');
    });
  });
  listEl.querySelectorAll('.staff-role-select').forEach(sel=>{
    sel.addEventListener('change', async e=>{
      const s = DATA.config.staff.find(x=>x.id===e.target.dataset.id);
      if(s) s.role = e.target.value;
      await saveData();
      showToast('Staff updated');
    });
  });
  listEl.querySelectorAll('[data-action="reset-pin"]').forEach(btn=>{
    btn.addEventListener('click', async e=>{
      const s = DATA.config.staff.find(x=>x.id===e.target.dataset.id);
      if(!s) return;
      const pin = prompt(`New PIN for ${s.name}:`);
      if(!pin || pin.trim().length < 4){ showToast('PIN needs at least 4 digits'); return; }
      s.pin = pin.trim();
      await saveData();
      showToast('PIN reset');
    });
  });
  listEl.querySelectorAll('[data-action="remove-staff"]').forEach(btn=>{
    btn.addEventListener('click', async e=>{
      const id = e.target.dataset.id;
      DATA.config.staff = DATA.config.staff.filter(x=>x.id!==id);
      await saveData();
      renderStaffList();
      showToast('Staff removed');
    });
  });
}

async function addStaff(){
  const nameInp = document.getElementById('new-staff-name');
  const pinInp = document.getElementById('new-staff-pin');
  const roleSel = document.getElementById('new-staff-role');
  if(!nameInp.value.trim()){ showToast('Enter a name first'); return; }
  if(!pinInp.value.trim() || pinInp.value.trim().length < 4){ showToast('PIN needs at least 4 digits'); return; }
  const id = 's' + Date.now();
  DATA.config.staff.push({id, name: nameInp.value.trim(), pin: pinInp.value.trim(), role: roleSel.value});
  await saveData();
  nameInp.value = ''; pinInp.value = '';
  renderStaffList();
  showToast('Staff added');
}

async function addUnit(){
  const nameInp = document.getElementById('new-unit-name');
  const typeSel = document.getElementById('new-unit-type');
  if(!nameInp.value.trim()){ showToast('Enter a unit name first'); return; }
  const id = 'u' + Date.now();
  DATA.config.units.push({id, name: nameInp.value.trim(), type: typeSel.value});
  await saveData();
  nameInp.value = '';
  renderSettings();
  showToast('Unit added');
}

async function saveDetails(){
  DATA.config.name = document.getElementById('set-name').value;
  DATA.config.license = document.getElementById('set-license').value;
  DATA.config.expiry = document.getElementById('set-expiry').value;
  DATA.config.location = document.getElementById('set-location').value;
  await saveData();
  document.getElementById('sb-restname').textContent = DATA.config.name || 'no restaurant set';
  showToast('Details saved');
  renderDashboard();
}

/* ---------------- Tabs & init ---------------- */
function switchTab(tab){
  document.querySelectorAll('nav button').forEach(b=>b.classList.toggle('active', b.dataset.tab===tab));
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  if(tab==='dashboard') renderDashboard();
  if(tab==='dailylog') renderDailyLog();
  if(tab==='history') renderHistory();
  if(tab==='checklist') renderChecklist();
  if(tab==='rules') renderRules();
  if(tab==='settings') renderSettings();
}

document.querySelectorAll('nav button').forEach(b=>{
  b.addEventListener('click', ()=>switchTab(b.dataset.tab));
});
document.getElementById('dl-save').addEventListener('click', saveDailyLog);
document.getElementById('add-unit-btn').addEventListener('click', addUnit);
document.getElementById('set-save-details').addEventListener('click', saveDetails);
document.getElementById('add-staff-btn').addEventListener('click', addStaff);
document.getElementById('login-btn').addEventListener('click', attemptLogin);
document.getElementById('logout-btn').addEventListener('click', doLogout);
document.getElementById('login-pin').addEventListener('keydown', e=>{ if(e.key==='Enter') attemptLogin(); });
document.getElementById('login-name').addEventListener('change', ()=>{
  document.getElementById('login-err').textContent = '';
});

(async function init(){
  await loadData();
  populateLoginNames();
  document.getElementById('sb-restname').textContent = DATA.config.name || 'no restaurant set';
})();
</script>
</body>
</html>
