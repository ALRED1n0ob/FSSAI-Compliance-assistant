function renderHistory(){
  const dates = Object.keys(DATA.dailyLogs).sort().reverse();
  const head = document.getElementById('history-head');
  const body = document.getElementById('history-body');
  const emptyEl = document.getElementById('history-empty');
  if(dates.length === 0){
    head.innerHTML = ''; body.innerHTML = '';
    emptyEl.style.display = 'block';
    return;
  }
  emptyEl.style.display = 'none';
  const units = DATA.config.units;
  head.innerHTML = `<th>Date</th>${units.map(u=>`<th>${u.name}</th>`).join('')}<th>Checks passed</th><th>Signed by</th>`;
  body.innerHTML = '';
  dates.forEach(d=>{
    const log = DATA.dailyLogs[d];
    const tr = document.createElement('tr');
    const tempCells = units.map(u=>{
      const reading = log.readings && log.readings[u.id] ? log.readings[u.id].temp : '';
      if(reading === '' || reading === undefined) return '<td style="color:var(--text-dim)">—</td>';
      const r = typeRange(u.type);
      const v = parseFloat(reading);
      const ok = !isNaN(v) && v >= r.min && v <= r.max;
      const who = log.readings[u.id].by ? ` <span style="color:var(--text-dim);">· ${log.readings[u.id].by}</span>` : '';
      return `<td style="color:${ok?'var(--green)':'var(--red)'}">${reading}°${who}</td>`;
    }).join('');
    const checksPassed = log.checks ? Object.values(log.checks).filter(Boolean).length : 0;
    const checksTotal = log.checks ? Object.keys(log.checks).length : 0;
    const signers = log.signatures && log.signatures.length
      ? [...new Set(log.signatures.map(s=>s.by))].join(', ')
      : (log.loggedBy || '—');
    tr.innerHTML = `<td>${prettyDate(d)}</td>${tempCells}<td>${checksPassed}/${checksTotal}</td><td>${signers}</td>`;
    body.appendChild(tr);
  });
}

