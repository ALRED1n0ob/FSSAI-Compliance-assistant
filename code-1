/* ---------------- Rendering: Dashboard ---------------- */
function renderDashboard(){
  document.getElementById('dash-date').textContent = prettyDate(todayStr());
  const today = todayStr();
  const log = DATA.dailyLogs[today] || null;
  const units = DATA.config.units;

  // temps count
  const readingsCount = log && log.readings ? Object.keys(log.readings).filter(k=>log.readings[k].temp !== '' && log.readings[k].temp !== undefined).length : 0;
  document.getElementById('dash-temps-count').textContent = `${readingsCount}/${units.length}`;

  // checklist daily count
  const dailyItems = CHECKLIST.flatMap(c=>c.items).filter(i=>i.freq==='daily');
  let doneToday = 0;
  dailyItems.forEach(i=>{
    const st = DATA.checklistState[i.id];
    if(st && st.lastDone === today) doneToday++;
  });
  document.getElementById('dash-checklist-count').textContent = `${doneToday}/${dailyItems.length}`;

  // alerts: out of range temps + overdue checklist items
  let alerts = 0;
  units.forEach(u=>{
    if(log && log.readings && log.readings[u.id] && log.readings[u.id].temp !== ''){
      const t = parseFloat(log.readings[u.id].temp);
      const r = typeRange(u.type);
      if(!isNaN(t) && (t < r.min || t > r.max)) alerts++;
    }
  });
  const overdue = getOverdueItems();
  alerts += overdue.length;
  document.getElementById('dash-alerts-count').textContent = alerts;

  const badge = document.getElementById('dash-compliance-badge');
  if(alerts === 0 && readingsCount === units.length && units.length>0){
    badge.innerHTML = `<b style="color:var(--green)">On track</b> — all units logged, no alerts`;
  } else if(alerts > 0){
    badge.innerHTML = `<b style="color:var(--red)">${alerts} issue${alerts>1?'s':''}</b> need attention`;
  } else {
    badge.innerHTML = `<b>${readingsCount}/${units.length}</b> units logged today`;
  }

  // gauges
  const gaugesEl = document.getElementById('dash-gauges');
  gaugesEl.innerHTML = '';
  if(units.length === 0){
    gaugesEl.innerHTML = '<div class="empty">No units configured — add them in Settings.</div>';
  }
  units.forEach(u=>{
    const r = typeRange(u.type);
    const reading = log && log.readings && log.readings[u.id] ? log.readings[u.id].temp : '';
    const val = reading === '' || reading === undefined ? null : parseFloat(reading);
    const inRange = val !== null && !isNaN(val) && val >= r.min && val <= r.max;
    const span = r.max - r.min;
    const displayMin = r.min - Math.max(2, span*0.3);
    const displayMax = r.max + Math.max(2, span*0.3);
    const pct = val === null ? 0 : Math.max(0, Math.min(100, ((val - displayMin)/(displayMax-displayMin))*100));
    const fillColor = val === null ? 'var(--text-dim)' : (inRange ? 'var(--green)' : 'var(--red)');
    const div = document.createElement('div');
    div.className = 'gaugeplate';
    div.innerHTML = `
      <div class="unit-name"><span>${u.name}</span><span class="pill ${val===null?'neutral':(inRange?'ok':'bad')}">${val===null?'no reading':(inRange?'in range':'out of range')}</span></div>
      <div class="gauge-row">
        <div class="gauge-track">
          <div class="gauge-fill" style="width:${val===null?0:pct}%; background:${fillColor};"></div>
        </div>
        <div class="gauge-reading" style="color:${fillColor}">${val===null?'—':val+'°'}</div>
      </div>
      <div class="gauge-range">target ${r.min}° to ${r.max}°</div>
    `;
    gaugesEl.appendChild(div);
  });
  document.getElementById('gauge-lastupdate').textContent = log ? '· updated today' : '· not logged today';

  // upcoming/overdue
  const upEl = document.getElementById('dash-upcoming');
  upEl.innerHTML = '';
  const items = [];
  if(DATA.config.expiry){
    const days = Math.ceil((new Date(DATA.config.expiry) - new Date())/86400000);
    if(days < 45){
      items.push({label:`FSSAI license expiry — ${DATA.config.expiry}`, days});
    }
  }
  overdue.forEach(o=>items.push({label:o.txt+` (${o.freq})`, days: -o.overdueBy}));
  if(items.length === 0){
    upEl.innerHTML = '<div class="empty">Nothing overdue. Nice work.</div>';
  } else {
    items.sort((a,b)=>a.days-b.days);
    items.forEach(it=>{
      const row = document.createElement('div');
      row.className = 'checkline';
      const overdueTxt = it.days < 0 ? `overdue by ${Math.abs(it.days)}d` : `due in ${it.days}d`;
      row.innerHTML = `<span class="txt">${it.label}</span><span class="pill ${it.days<0?'bad':'warn'}">${overdueTxt}</span>`;
      upEl.appendChild(row);
    });
  }
}

function getOverdueItems(){
  const today = new Date();
  const result = [];
  CHECKLIST.flatMap(c=>c.items).forEach(i=>{
    if(i.freq === 'daily') return; // daily items don't count as "overdue" long-term, tracked separately
    const st = DATA.checklistState[i.id];
    const freqDays = FREQ_DAYS[i.freq];
    if(!st || !st.lastDone){
      result.push({...i, overdueBy: freqDays});
      return;
    }
    const last = new Date(st.lastDone);
    const diffDays = Math.floor((today - last)/86400000);
    if(diffDays > freqDays){
      result.push({...i, overdueBy: diffDays - freqDays});
    }
  });
  return result;
}

